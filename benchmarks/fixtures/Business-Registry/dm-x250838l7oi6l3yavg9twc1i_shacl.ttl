            sh:maxCount 1 ;
            sh:message "XdTemporal datetime must be a valid datetime" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-datetime ],
        [ sh:datatype xsd:time ;
            sh:maxCount 1 ;
            sh:message "XdTemporal time must be a valid time" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-time ],
        [ sh:datatype xsd:gYearMonth ;
            sh:maxCount 1 ;
            sh:message "XdTemporal year-month must be a valid gYearMonth" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-year-month ] ;
    sh:targetClass sdc4:XdTemporalType .

sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape a sh:NodeShape ;
    rdfs:label "City" ;
    rdfs:comment "One of the nine cities in the Republic of Cordova." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "City" ;
            sh:hasValue <http://schema.org/City> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Porto Sereno" "Vistamar" "Rioseco" "Campoluz" "Tierraverde" "Montecara" "Novaciudad" "Piedrasol" "Lagunavista" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ] ;
    sh:targetNode sdc4:mc-atdtdfzruh7tya0iv5cz365l ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-cs34ekiq4o9pazzs5baiobis-shape a sh:NodeShape ;
    rdfs:label "Status" ;
    rdfs:comment "Current registration status" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "Status indicator (Q856698)" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q856698> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Active" "Suspended" "Dissolved" ) ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetNode sdc4:mc-cs34ekiq4o9pazzs5baiobis ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-ek5h6dsqpd9kz0l4mcckmxpt-shape a sh:NodeShape ;
    rdfs:label "Address (Line 2)" ;
    rdfs:comment "Street address line, building/apartment number, or P.O. Box number." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxLength 200 ;
            sh:path sdc4:xdstring-value ],
        [ rdfs:label "Street Address" ;
            sh:hasValue schema:streetAddress ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-ek5h6dsqpd9kz0l4mcckmxpt ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-gu15c6jojx09jy9at1px0ufh-shape a sh:NodeShape ;
    rdfs:label "Organization Tax ID" ;
    rdfs:comment "A tax identification number (TIN/EIN) for an organization (NIEM nc:OrganizationTaxIdentification)" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "Employer Identification Number" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q2397748> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 50 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-gu15c6jojx09jy9at1px0ufh ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-kv5qqs3o4jwcwz9javgw1pzh-shape a sh:NodeShape ;
    rdfs:label "Province" ;
    rdfs:comment "One of the three provinces of the Republic of Cordova. Used across civil registry, property, tax, and all geographic records." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "AdministrativeArea" ;
            sh:hasValue <http://schema.org/AdministrativeArea> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "State/Province" ;
            sh:hasValue schema:State ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Aldara" "Brevina" "Celara" ) ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetNode sdc4:mc-kv5qqs3o4jwcwz9javgw1pzh ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-l338k7nlvnq2am0owa19yxfc-shape a sh:NodeShape ;
    rdfs:label "Address (Line 1)" ;
    rdfs:comment "Street address line, building/apartment number, or P.O. Box number." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "Street Address" ;
            sh:hasValue schema:streetAddress ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ],
        [ sh:datatype xsd:string ;
            sh:maxLength 200 ;
            sh:path sdc4:xdstring-value ] ;
    sh:targetNode sdc4:mc-l338k7nlvnq2am0owa19yxfc ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-l8f0m7op4xhrxqy1jrnvbuly-shape a sh:NodeShape ;
    rdfs:label "Business Registry Number" ;
    rdfs:comment "Cordova Business Registration Number. Format: BIZ-NNNNNN where NNNNNN is a six-digit sequence number assigned at incorporation. Required for all business filings, tax records, and port authority transactions." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "schema:identifier" ;
            sh:hasValue schema:identifier ;
            sh:path skos:broadMatch ],
        [ rdfs:label "business premises" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q12047291> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 10 ;
            sh:minLength 10 ;
            sh:path sdc4:xdstring-value ;
            sh:pattern "BIZ-[0-9]{6}" ],
        [ rdfs:label "identifier" ;
            sh:hasValue <http://schema.org/identifier> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-l8f0m7op4xhrxqy1jrnvbuly ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-m0i63npis09ch7ag08ntoneu-shape a sh:NodeShape ;
    rdfs:label "Industry" ;
    rdfs:comment "Primary industry classification" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ sh:datatype xsd:token ;
            sh:in ( "Agriculture" "Manufacturing" "Shipping" "Retail" "Healthcare" "Education" "Technology" "Construction" "Finance" "Government Services" "Hospitality" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "industry classification" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q2976602> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-m0i63npis09ch7ag08ntoneu ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-nfrvvp87c5imu5h9ups92kgy-shape a sh:NodeShape ;
    rdfs:label "Cordova Phone Number" ;
    rdfs:comment "Cordova national telephone number. Format: +99-PPP-NNN-NNNN where +99 is the country code and PPP is the area code. Area codes: Porto Sereno=100, Vistamar=110, Rioseco=120, Campoluz=200, Tierraverde=210, Montecara=220, Novaciudad=300, Piedrasol=310, Lagunavista=320." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "Telephone Number" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q214995> ;
            sh:path skos:relatedMatch ],
        [ sh:datatype xsd:string ;
            sh:maxLength 16 ;
            sh:minLength 16 ;
            sh:path sdc4:xdstring-value ;
            sh:pattern "\\+99-[123][012]0-[0-9]{3}-[0-9]{4}" ],
        [ rdfs:label "telephone number" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q214995> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-nfrvvp87c5imu5h9ups92kgy ;
    sdc4-meta:sdcType "XdStringType" .

