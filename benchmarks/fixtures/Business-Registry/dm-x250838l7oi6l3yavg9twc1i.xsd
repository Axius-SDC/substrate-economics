          <sdc4-meta:ModelComponent rdf:about="sdc4:mc-nj7s1gk45tfgyooxpz0qaha3"/>
          <sdc4-meta:describesConceptualEntity rdf:resource="sdc4:concept-national_id_(cid)"/>
          <rdfs:isDefinedBy rdf:resource="http://schema.org/identifier"/>
          <rdfs:isDefinedBy rdf:resource="https://www.wikidata.org/wiki/Q1140371"/>
          <skos:broadMatch rdf:resource="https://schema.org/identifier"/>
        </rdf:Description>
      </xsd:appinfo>
    </xsd:annotation>
    <xsd:complexContent>
      <xsd:restriction base="sdc4:XdStringType">
        <xsd:sequence>
          <xsd:element maxOccurs="1" minOccurs="1" name="label" type="xsd:string" fixed="National ID (CID)"/>
          <xsd:element maxOccurs="1" minOccurs="0" name="act" type="xsd:string"/>
          <xsd:element maxOccurs="1" minOccurs="0" ref="sdc4:ExceptionalValue"/>
          <xsd:element maxOccurs="1" minOccurs="0" name="vtb" type="xsd:dateTime"/>
          <xsd:element maxOccurs="1" minOccurs="0" name="vte" type="xsd:dateTime"/>
          <xsd:element maxOccurs="1" minOccurs="0" name="tr" type="xsd:dateTime"/>
          <xsd:element maxOccurs="1" minOccurs="0" name="modified" type="xsd:dateTime"/>
          <xsd:element maxOccurs="1" minOccurs="0" name="latitude" type="sdc4:lattype" nillable="true"/>
          <xsd:element maxOccurs="1" minOccurs="0" name="longitude" type="sdc4:lontype" nillable="true"/>
          <xsd:element maxOccurs="1" minOccurs="1" name="xdstring-value">
            <xsd:simpleType>
              <xsd:restriction base="xsd:string">
                <xsd:pattern value="COR-(AL|BR|CE)0[1-3]-[0-9]{6}"/>
              </xsd:restriction>
            </xsd:simpleType>
          </xsd:element>
          <xsd:element maxOccurs="1" minOccurs="0" name="xdstring-language" type="xsd:language" default="en-US"/>
        </xsd:sequence>
      </xsd:restriction>
    </xsd:complexContent>
  </xsd:complexType>


