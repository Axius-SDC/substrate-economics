    sh:targetNode sdc4:mc-eoqim4xj9gsxtxrqko1hh55o ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-hc91pdnj3bb6997l5z4ndchz-shape a sh:NodeShape ;
    rdfs:label "Charge Category (Cordova)" ;
    rdfs:comment "Categories of misdemeanor offenses in Cordova law enforcement records. Cordova has no felony classification — all criminal matters are misdemeanor-level." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "Criminal charge (Q1752346)" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1752346> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ sh:datatype xsd:token ;
            sh:in ( "Petty Theft" "Public Intoxication" "Trespassing" "Disorderly Conduct" "Traffic Violation" "Minor Vandalism" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ] ;
    sh:targetNode sdc4:mc-hc91pdnj3bb6997l5z4ndchz ;
    sdc4-meta:sdcType "XdTokenType" .

