sdc4:dm-yh0opq0bnu6y9y56oukg92uf-shape a sh:NodeShape ;
    rdfs:label "Law Enforcement Record" ;
    dc:coverage "Universal" ;
    dc:language "en-US" ;
    dc:rights "CC-BY http://creativecommons.org/licenses/by/3.0/" ;
    rdfs:comment "Record public safety incidents, charges, and dispositions in Cordova." ;
    sh:node sdc4:DMBaseShape ;
    sh:property [ sh:maxCount 1 ;
            sh:message "Data Model must have a root data Cluster" ;
            sh:minCount 1 ;
            sh:node sdc4:mc-songhwxr1fp8niqba4fd0yd9-shape ;
            sh:path sdc4:dm-data ] ;
    sh:targetNode sdc4:dm-yh0opq0bnu6y9y56oukg92uf ;
    sdc4:dm-encoding "utf-8" ;
    sdc4:dm-language "en-US" ;
    sdc4-meta:generatedAt "2026-03-08T03:26:41.019426+00:00"^^xsd:dateTime .

sdc4:DMBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-label ],
        [ sh:datatype xsd:language ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify a language" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-language ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify encoding" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-encoding ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a mandatory instance_id (CUID2)" ;
            sh:minCount 1 ;
            sh:path sdc4:instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_version_id ] ;
    sh:targetClass sdc4:DMType .

