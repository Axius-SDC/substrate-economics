sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape a sh:NodeShape ;
    rdfs:label "City" ;
    rdfs:comment "One of the nine cities in the Republic of Cordova." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "City" ;
            sh:hasValue <http://schema.org/City> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ sh:datatype xsd:token ;
            sh:in ( "Porto Sereno" "Vistamar" "Rioseco" "Campoluz" "Tierraverde" "Montecara" "Novaciudad" "Piedrasol" "Lagunavista" ) ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetNode sdc4:mc-atdtdfzruh7tya0iv5cz365l ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-avmmc3r38dol0ghko42yeyp4-shape a sh:NodeShape ;
    rdfs:label "Quarantine Enforcement" ;
    rdfs:comment """Special sub-cluster for public health quarantine orders. Used in the Contagion scenario.
Business Context: Links Law Enforcement to Healthcare domain through quarantine orders
Purpose: Document quarantine zone establishment and compliance monitoring
Parent Cluster: Incident Report""" ;
    sh:message "Assert: not(w33a4q5hoiqnex7t3dv5v43v/xdtemporal-date) or hcsadpovanyp7x6p8wwnw6k6/xdtemporal-date le w33a4q5hoiqnex7t3dv5v43v/xdtemporal-date" ;
    sh:node sdc4:ClusterBaseShape ;
    sh:property [ rdfs:label "schema:ItemList" ;
            sh:hasValue schema:ItemList ;
            sh:path skos:broadMatch ],
        [ sh:node sdc4:mc-ixmedhicidzpi7g6g2huqzvv-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "quarantine" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q186588> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-r34gm210y9jifbyxa0fcxy96-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-lohvu07ok3c3xvesa16htf2m-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-vq30hd0dl6v59d3ttyyvg6rp-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "IMO Tonnage Measurement Convention" ;
            sh:hasValue <https://www.imo.org/en/about/conventions/pages/international-convention-on-tonnage-measurement-of-ships.aspx> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-ihoatduhb7fckjw0ezq5u7g1-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ] ;
    sh:targetNode sdc4:mc-avmmc3r38dol0ghko42yeyp4 .

sdc4:mc-b6nahtg2we4rh5qsk2j7qfvz-shape a sh:NodeShape ;
    rdfs:label "Location Street Full Text" ;
    rdfs:comment "A complete street address (NIEM nc:LocationStreetFullText). BFO alignment: address is an information content entity (IAO:0000030) referring to a site (BFO:0000029)." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "street address" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q24574749> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 200 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-b6nahtg2we4rh5qsk2j7qfvz ;
    sdc4-meta:sdcType "XdStringType" .

