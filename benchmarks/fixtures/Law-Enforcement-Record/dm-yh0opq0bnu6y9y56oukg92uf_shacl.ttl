            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-rnje7nq6m08vh01g8eg23say-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-yahksk4xc5to981ows7bpp6z-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-l0esdclu01pg7qw429oe7kjk-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "schema:ItemList" ;
