sdc4:mc-e83h36jqgi59dhy1dttp22qm-shape a sh:NodeShape ;
    rdfs:label "Incident Status" ;
    rdfs:comment "Current status of the incident" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ sh:datatype xsd:token ;
            sh:in ( "Open" "Closed" "Pending" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "Status (Q2443992)" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q2443992> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-e83h36jqgi59dhy1dttp22qm ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-eoqim4xj9gsxtxrqko1hh55o-shape a sh:NodeShape ;
    rdfs:label "Charge Description" ;
    rdfs:comment "A description of a charge (NIEM j:ChargeDescriptionText)" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
