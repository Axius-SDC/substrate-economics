  },
  "components": [
    {
      "@type": "ClusterType",
      "@id": "sdc4:mc-songhwxr1fp8niqba4fd0yd9",
      "label": "Incident Report",
      "description": "A single public safety incident recorded by Cordova National Police.\nBusiness Context: Links to Civil Registry for person identification\nPurpose: Document an incident with location, category, involved parties, and outcome",
      "cardinality": {
        "minOccurs": 0,
        "maxOccurs": 1
      },
      "contains": [
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-yi2189u4pinqitlmm5t6ccrd",
          "label": "Incident Report Number",
          "description": "A report number for an incident (NIEM j:IncidentReportNumber)",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "constraints": {
            "minLength": 1,
            "maxLength": 50
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdf:type",
              "object": "https://schema.org/Text"
            },
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "https://www.wikidata.org/wiki/Q111653916"
            }
          ]
        },
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-rguhpkd7s2d9a51392aon7ir",
          "label": "Incident Summary",
          "description": "Brief summary of incident (one paragraph)",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "constraints": {
            "minLength": 1,
            "maxLength": 2000
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "http://schema.org/description"
            },
            {
              "predicate": "rdf:type",
              "object": "https://schema.org/Text"
            }
          ]
        },
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-b6nahtg2we4rh5qsk2j7qfvz",
          "label": "Location Street Full Text",
          "description": "A complete street address (NIEM nc:LocationStreetFullText). BFO alignment: address is an information content entity (IAO:0000030) referring to a site (BFO:0000029).",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "constraints": {
            "minLength": 1,
            "maxLength": 200
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdf:type",
