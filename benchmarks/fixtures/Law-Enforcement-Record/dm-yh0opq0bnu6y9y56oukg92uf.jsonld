  "label": "Law Enforcement Record",
  "description": "Record public safety incidents, charges, and dispositions in Cordova.",
  "metadata": {
    "dc:title": "Law Enforcement Record",
    "dc:creator": "Timothy Cook",
    "dc:description": "Record public safety incidents, charges, and dispositions in Cordova.",
