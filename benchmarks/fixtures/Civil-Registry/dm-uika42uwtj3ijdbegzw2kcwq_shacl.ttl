sdc4:mc-cfg2l8ym4ve833ritrxu765t-shape a sh:NodeShape ;
    rdfs:label "Country of Birth" ;
    rdfs:comment "Country where participant was born" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ],
        [ rdfs:label "Country of birth" ;
            sh:hasValue <https://uts.nlm.nih.gov/uts/umls/concept/C1300001> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 200 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ] ;
    sh:targetNode sdc4:mc-cfg2l8ym4ve833ritrxu765t ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-cymq16em5zb20whgtfzki6n5-shape a sh:NodeShape ;
    rdfs:label "Gender Identity" ;
    rdfs:comment "Self-reported gender identity of the participant" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ sh:datatype xsd:token ;
            sh:in ( "Male" "Female" "Transgender male" "Transgender female" "Non-binary" "Genderqueer" "Other" "Prefer not to answer" "Unknown" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "Gender Identity" ;
            sh:hasValue <https://uts.nlm.nih.gov/uts/umls/concept/C0017249> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ] ;
    sh:targetNode sdc4:mc-cymq16em5zb20whgtfzki6n5 ;
    sdc4-meta:sdcType "XdTokenType" .

