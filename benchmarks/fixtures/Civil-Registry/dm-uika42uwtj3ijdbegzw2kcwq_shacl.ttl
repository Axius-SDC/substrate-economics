sdc4:mc-mw9qdn71urog8egjbp5t3y00-shape a sh:NodeShape ;
    rdfs:label "Sex" ;
    rdfs:comment "Biological sex assigned at birth based on physical characteristics. UMLS CUI: C0079399 (Biologic Sex). Aligned with OMB standards for reporting." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ sh:datatype xsd:token ;
            sh:in ( "Male" "Female" "Intersex" "Unknown" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "Biological sex" ;
            sh:hasValue <https://uts.nlm.nih.gov/uts/umls/concept/C5236503> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-mw9qdn71urog8egjbp5t3y00 ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-nfrvvp87c5imu5h9ups92kgy-shape a sh:NodeShape ;
    rdfs:label "Cordova Phone Number" ;
    rdfs:comment "Cordova national telephone number. Format: +99-PPP-NNN-NNNN where +99 is the country code and PPP is the area code. Area codes: Porto Sereno=100, Vistamar=110, Rioseco=120, Campoluz=200, Tierraverde=210, Montecara=220, Novaciudad=300, Piedrasol=310, Lagunavista=320." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "Telephone Number" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q214995> ;
            sh:path skos:relatedMatch ],
        [ rdfs:label "telephone number" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q214995> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 16 ;
            sh:minLength 16 ;
            sh:path sdc4:xdstring-value ;
            sh:pattern "\\+99-[123][012]0-[0-9]{3}-[0-9]{4}" ] ;
    sh:targetNode sdc4:mc-nfrvvp87c5imu5h9ups92kgy ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-nj7s1gk45tfgyooxpz0qaha3-shape a sh:NodeShape ;
    rdfs:label "National ID (CID)" ;
    rdfs:comment "Cordova National Identity Number. Format: COR-PPCC-NNNNNN where PP is the two-letter province code (AL=Aldara, BR=Brevina, CE=Celara), CC is the two-digit city code (01-03), and NNNNNN is a six-digit sequence number. Issued at birth or naturalization. Required for all government transactions." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "schema:identifier" ;
            sh:hasValue schema:identifier ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:string ;
            sh:maxLength 16 ;
            sh:minLength 16 ;
            sh:path sdc4:xdstring-value ;
            sh:pattern "COR-(AL|BR|CE)0[1-3]-[0-9]{6}" ],
        [ rdfs:label "national identification number" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1140371> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "identifier" ;
            sh:hasValue <http://schema.org/identifier> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-nj7s1gk45tfgyooxpz0qaha3 ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-o7vjxwswi0pxo543hq504jjx-shape a sh:NodeShape ;
    rdfs:label "Relationship End Date" ;
    rdfs:comment "Date the relationship ended, if applicable (e.g., divorce date, death date). Null for active relationships." ;
    sh:node sdc4:XdTemporalBaseShape ;
    sh:property [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path sdc4:xdtemporal-date ],
        [ rdfs:label "schema:Date" ;
            sh:hasValue schema:Date ;
            sh:path skos:broadMatch ],
        [ rdfs:label "termination date" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q121875611> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-o7vjxwswi0pxo543hq504jjx ;
    sdc4-meta:sdcType "XdTemporalType" .

sdc4:mc-oit0ueglhjfcyq80z22kl2z3-shape a sh:NodeShape ;
    rdfs:label "Middle Name (Person)" ;
    rdfs:comment "Middle or other name(s) given to identify a person" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxLength 100 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ],
        [ rdfs:label "Middle Name" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q245025> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-oit0ueglhjfcyq80z22kl2z3 ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-sv48g8am8vqs46nodiugripz-shape a sh:NodeShape ;
    rdfs:label "Contact Information" ;
    rdfs:comment """Phone, email, and preferred contact method for the person.
Purpose: Enable government communication with the person
Parent Cluster: Civil Registry Record""" ;
    sh:node sdc4:ClusterBaseShape ;
    sh:property [ sh:node sdc4:mc-nfrvvp87c5imu5h9ups92kgy-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-x0na649n17if0ukul82cmrx3-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-zlz64jydsmhb5zmytcm2ewyg-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "contact information" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q2996679> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:ItemList" ;
            sh:hasValue schema:ItemList ;
            sh:path skos:broadMatch ] ;
    sh:targetNode sdc4:mc-sv48g8am8vqs46nodiugripz .

sdc4:mc-v8jgjo2sml12jo7zrb8swoxi-shape a sh:NodeShape ;
    rdfs:label "Surname (Person)" ;
    rdfs:comment """The surname or family name of a person, part of a naming scheme for individuals, used in many cultures worldwide\r
aka: last name, fam name, family surname, surname, clan name""" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxLength 100 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ],
        [ rdfs:label "Family Name" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q101352> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-v8jgjo2sml12jo7zrb8swoxi ;
    sdc4-meta:require_act true ;
    sdc4-meta:require_vtb true ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-vjfgimlbb90ds2xg55tfn941-shape a sh:NodeShape ;
    rdfs:label "Marital Status (Cordova)" ;
    rdfs:comment "Marital status as recorded in the Cordova Civil Registry. Aligned with vital statistics records." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ sh:datatype xsd:token ;
            sh:in ( "Single" "Married" "Divorced" "Widowed" "Separated" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "marital status" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q11920938> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ] ;
    sh:targetNode sdc4:mc-vjfgimlbb90ds2xg55tfn941 ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-x0na649n17if0ukul82cmrx3-shape a sh:NodeShape ;
    rdfs:label "Cordova Email Address" ;
    rdfs:comment "Email address using one of the Cordova national email providers. Providers: cordomail.co, novamail.co, portocorreo.co" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxLength 254 ;
            sh:minLength 5 ;
            sh:path sdc4:xdstring-value ;
            sh:pattern "[-a-zA-Z0-9._%+]+@(cordomail|novamail|portocorreo)\\.co" ],
        [ rdfs:label "email address" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1273217> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:name" ;
            sh:hasValue schema:name ;
            sh:path skos:broadMatch ] ;
    sh:targetNode sdc4:mc-x0na649n17if0ukul82cmrx3 ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-ytctcqbr30kxsmvx4jk7lae2-shape a sh:NodeShape ;
    rdfs:label "Current Address" ;
    rdfs:comment """The person's current residential address within Cordova.
Purpose: Current residential address for correspondence and jurisdiction determination
Parent Cluster: Civil Registry Record""" ;
    sh:node sdc4:ClusterBaseShape ;
    sh:property [ sh:node sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-ek5h6dsqpd9kz0l4mcckmxpt-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-kv5qqs3o4jwcwz9javgw1pzh-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-l338k7nlvnq2am0owa19yxfc-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "schema:ItemList" ;
            sh:hasValue schema:ItemList ;
            sh:path skos:broadMatch ],
        [ rdfs:label "current location" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q75618710> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-ytctcqbr30kxsmvx4jk7lae2 .

sdc4:mc-zlz64jydsmhb5zmytcm2ewyg-shape a sh:NodeShape ;
    rdfs:label "Preferred Contact Method" ;
    rdfs:comment "Participant's preferred method of contact" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "Communication channel (Q2336001)" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q2336001> ;
            sh:path skos:relatedMatch ],
        [ sh:datatype xsd:token ;
            sh:in ( "Phone" "Email" "Text/SMS" "Mail" "No preference" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-zlz64jydsmhb5zmytcm2ewyg ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape a sh:NodeShape ;
    rdfs:label "City" ;
    rdfs:comment "One of the nine cities in the Republic of Cordova." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "City" ;
            sh:hasValue <http://schema.org/City> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Porto Sereno" "Vistamar" "Rioseco" "Campoluz" "Tierraverde" "Montecara" "Novaciudad" "Piedrasol" "Lagunavista" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-atdtdfzruh7tya0iv5cz365l ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-kv5qqs3o4jwcwz9javgw1pzh-shape a sh:NodeShape ;
    rdfs:label "Province" ;
    rdfs:comment "One of the three provinces of the Republic of Cordova. Used across civil registry, property, tax, and all geographic records." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "State/Province" ;
            sh:hasValue schema:State ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "AdministrativeArea" ;
            sh:hasValue <http://schema.org/AdministrativeArea> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Aldara" "Brevina" "Celara" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ] ;
    sh:targetNode sdc4:mc-kv5qqs3o4jwcwz9javgw1pzh ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:XdTemporalBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdTemporal must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:message "XdTemporal date must be a valid date" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-date ],
        [ sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:message "XdTemporal datetime must be a valid datetime" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-datetime ],
        [ sh:datatype xsd:time ;
            sh:maxCount 1 ;
            sh:message "XdTemporal time must be a valid time" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-time ],
        [ sh:datatype xsd:gYearMonth ;
            sh:maxCount 1 ;
            sh:message "XdTemporal year-month must be a valid gYearMonth" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-year-month ] ;
    sh:targetClass sdc4:XdTemporalType .

sdc4:ClusterBaseShape a sh:NodeShape ;
    sh:property [ sh:message "Cluster can contain zero or more components" ;
            sh:minCount 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Cluster must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ] ;
    sh:targetClass sdc4:ClusterType .

sdc4:XdTokenBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdToken must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:token ;
            sh:maxCount 1 ;
            sh:message "XdToken must have a token value" ;
            sh:minCount 1 ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetClass sdc4:XdTokenType .

sdc4:XdStringBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdString must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdString value must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:xdstring-value ],
        [ sh:datatype xsd:language ;
            sh:maxCount 1 ;
            sh:message "XdString language must be a valid language code" ;
            sh:minCount 0 ;
            sh:path sdc4:xdstring-language ] ;
    sh:targetClass sdc4:XdStringType .

