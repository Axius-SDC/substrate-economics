        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_version_id ] ;
    sh:targetClass sdc4:DMType .

sdc4:mc-be9apjt8mvjjv86qzycorcjl-shape a sh:NodeShape ;
    rdfs:label "Relationship Type" ;
    rdfs:comment "Familial or legal relationship between two persons in the Cordova Civil Registry." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ sh:datatype xsd:token ;
            sh:in ( "Spouse" "Parent" "Child" "Sibling" "Grandparent" "Grandchild" "Guardian" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "family relation" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q69901743> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-be9apjt8mvjjv86qzycorcjl ;
    sdc4-meta:sdcType "XdTokenType" .

