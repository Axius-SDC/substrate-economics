  "label": "Civil Registry",
  "description": "Maintain the authoritative identity record for every person in Cordova.",
  "metadata": {
    "dc:title": "Civil Registry",
    "dc:creator": "Timothy Cook",
    "dc:description": "Maintain the authoritative identity record for every person in Cordova.",
