  "components": [
    {
      "@type": "ClusterType",
      "@id": "sdc4:mc-bgjt4mvgvkxcn6hurg37u21b",
      "label": "Civil Registry Record",
      "description": "A complete civil registry entry for one person. This is the anchor node in the Cordova graph — the Person cell that every other domain references.\nBusiness Context: Authoritative source of truth for all government identity verification\nPurpose: Complete identity record for a Cordova resident",
      "cardinality": {
        "minOccurs": 0,
        "maxOccurs": 1
      },
      "contains": [
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-nj7s1gk45tfgyooxpz0qaha3",
          "label": "National ID (CID)",
          "description": "Cordova National Identity Number. Format: COR-PPCC-NNNNNN where PP is the two-letter province code (AL=Aldara, BR=Brevina, CE=Celara), CC is the two-digit city code (01-03), and NNNNNN is a six-digit sequence number. Issued at birth or naturalization. Required for all government transactions.",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "http://schema.org/identifier"
            },
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "https://www.wikidata.org/wiki/Q1140371"
            },
            {
              "predicate": "skos:broadMatch",
              "object": "https://schema.org/identifier"
            }
          ]
        },
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-cfg2l8ym4ve833ritrxu765t",
          "label": "Country of Birth",
          "description": "Country where participant was born",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "constraints": {
            "minLength": 1,
            "maxLength": 200
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdfs:isDefinedBy",
