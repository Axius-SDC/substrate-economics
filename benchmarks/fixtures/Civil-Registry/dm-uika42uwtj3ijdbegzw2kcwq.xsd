          <xsd:element maxOccurs="1" minOccurs="1" name="xdstring-value">
            <xsd:simpleType>
              <xsd:restriction base="xsd:string">
                <xsd:pattern value="\+99-[123][012]0-[0-9]{3}-[0-9]{4}"/>
              </xsd:restriction>
            </xsd:simpleType>
          </xsd:element>
          <xsd:element maxOccurs="1" minOccurs="0" name="xdstring-language" type="xsd:language" default="en-US"/>
