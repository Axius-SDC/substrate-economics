            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "Academic distinction (Q11415564)" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q11415564> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-c7qvfjtu0omg4wagiaiy5hej ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-g6ntdb41otp1mtwsyb52mez3-shape a sh:NodeShape ;
    rdfs:label "Expected Completion Date" ;
    rdfs:comment """Expected date of program completion

---""" ;
    sh:node sdc4:XdTemporalBaseShape ;
