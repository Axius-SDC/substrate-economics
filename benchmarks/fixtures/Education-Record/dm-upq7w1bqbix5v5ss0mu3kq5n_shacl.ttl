sdc4:mc-kv5qqs3o4jwcwz9javgw1pzh-shape a sh:NodeShape ;
    rdfs:label "Province" ;
    rdfs:comment "One of the three provinces of the Republic of Cordova. Used across civil registry, property, tax, and all geographic records." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "AdministrativeArea" ;
            sh:hasValue <http://schema.org/AdministrativeArea> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ sh:datatype xsd:token ;
            sh:in ( "Aldara" "Brevina" "Celara" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "State/Province" ;
            sh:hasValue schema:State ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ] ;
    sh:targetNode sdc4:mc-kv5qqs3o4jwcwz9javgw1pzh ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-nj7s1gk45tfgyooxpz0qaha3-shape a sh:NodeShape ;
    rdfs:label "National ID (CID)" ;
    rdfs:comment "Cordova National Identity Number. Format: COR-PPCC-NNNNNN where PP is the two-letter province code (AL=Aldara, BR=Brevina, CE=Celara), CC is the two-digit city code (01-03), and NNNNNN is a six-digit sequence number. Issued at birth or naturalization. Required for all government transactions." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "national identification number" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1140371> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 16 ;
            sh:minLength 16 ;
            sh:path sdc4:xdstring-value ;
            sh:pattern "COR-(AL|BR|CE)0[1-3]-[0-9]{6}" ],
        [ rdfs:label "identifier" ;
            sh:hasValue <http://schema.org/identifier> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:identifier" ;
            sh:hasValue schema:identifier ;
            sh:path skos:broadMatch ] ;
    sh:targetNode sdc4:mc-nj7s1gk45tfgyooxpz0qaha3 ;
    sdc4-meta:sdcType "XdStringType" .

