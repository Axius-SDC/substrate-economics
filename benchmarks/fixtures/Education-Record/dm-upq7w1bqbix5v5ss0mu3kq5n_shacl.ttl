    sh:message "Assert: not(i9d2a0yw59wetmxg7vbwcx29/xdtemporal-date) or jq4iz20sychk8tbfv0czux92/xdtemporal-date le i9d2a0yw59wetmxg7vbwcx29/xdtemporal-date" ;
    sh:node sdc4:ClusterBaseShape ;
    sh:property [ sh:node sdc4:mc-z72jnzdib9hi311s338zwdog-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "schema:ItemList" ;
            sh:hasValue schema:ItemList ;
            sh:path skos:broadMatch ],
        [ rdfs:label "enrollment" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q102252225> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "CDC Immunization Schedules" ;
            sh:hasValue <https://www.cdc.gov/vaccines/hcp/imz-schedules/index.html> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-squd8e2s6pk8xoafu9ec0t9k-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-ouqi09d8kjqeojlr7vnclysj-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-1ylumrkck2vv635djov01tte4-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-g6ntdb41otp1mtwsyb52mez3-shape ;
            sh:order 0 ;
