            sh:path sdc4:xdordinal-symbol ] ;
    sh:targetClass sdc4:XdOrdinalType .

sdc4:mc-1ylumrkck2vv635djov01tte4-shape a sh:NodeShape ;
    rdfs:label "Education Level" ;
    rdfs:comment "Highest level of education completed" ;
    sh:node sdc4:XdOrdinalBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "highest level of education completed" ;
            sh:hasValue <https://uts.nlm.nih.gov/uts/umls/concept/C2030935> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ sh:in ( "Less than high school" "High school diploma/GED" "Some college" "Associate degree" "Bachelor's degree" "Master's degree" "Doctoral degree" "Unknown" ) ;
            sh:path sdc4:xdordinal-symbol ],
        [ sh:in ( "0" "1" "2" "3" "4" "5" "6" "7" ) ;
            sh:path sdc4:xdordinal-value ] ;
    sh:targetNode sdc4:mc-1ylumrkck2vv635djov01tte4 ;
    sdc4-meta:sdcType "XdOrdinalType" .

sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape a sh:NodeShape ;
    rdfs:label "City" ;
    rdfs:comment "One of the nine cities in the Republic of Cordova." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ sh:datatype xsd:token ;
            sh:in ( "Porto Sereno" "Vistamar" "Rioseco" "Campoluz" "Tierraverde" "Montecara" "Novaciudad" "Piedrasol" "Lagunavista" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "City" ;
            sh:hasValue <http://schema.org/City> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-atdtdfzruh7tya0iv5cz365l ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-c7qvfjtu0omg4wagiaiy5hej-shape a sh:NodeShape ;
    rdfs:label "Honors" ;
    rdfs:comment "Academic honors received, if any" ;
