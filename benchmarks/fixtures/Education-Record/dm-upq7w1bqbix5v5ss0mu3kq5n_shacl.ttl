    sh:targetNode sdc4:mc-r97mt4prbpxp04qmdc8iimb8 .

sdc4:mc-squd8e2s6pk8xoafu9ec0t9k-shape a sh:NodeShape ;
    rdfs:label "Enrollment Status" ;
    rdfs:comment "Current enrollment status" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "recruitment status" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q76649493> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Active" "Graduated" "Withdrawn" "Suspended" "On Leave" ) ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetNode sdc4:mc-squd8e2s6pk8xoafu9ec0t9k ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-sxkjp09cbjb6n13j8a0eg37i-shape a sh:NodeShape ;
    rdfs:label "Credential Type" ;
    rdfs:comment "Type of academic credential awarded" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "type" ;
            sh:hasValue <https://www.w3.org/2018/credentials#type> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ sh:datatype xsd:token ;
            sh:in ( "Primary Certificate" "Secondary Diploma" "Associate Degree" "Bachelor's Degree" "Master's Degree" "Doctoral Degree" "Professional Certificate" ) ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetNode sdc4:mc-sxkjp09cbjb6n13j8a0eg37i ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-xi99tao4v75wdrkq0ot02vfd-shape a sh:NodeShape ;
    rdfs:label "Date Awarded" ;
    rdfs:comment "Date the credential was officially awarded" ;
    sh:node sdc4:XdTemporalBaseShape ;
    sh:property [ rdfs:label "schema:Date" ;
            sh:hasValue schema:Date ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path sdc4:xdtemporal-date ],
        [ rdfs:label "Date Issued" ;
            sh:hasValue dcterms:issued ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-xi99tao4v75wdrkq0ot02vfd ;
    sdc4-meta:sdcType "XdTemporalType" .

sdc4:mc-z72jnzdib9hi311s338zwdog-shape a sh:NodeShape ;
    rdfs:label "Enrollment Date" ;
    rdfs:comment "Date the student enrolled in the program" ;
    sh:node sdc4:XdTemporalBaseShape ;
    sh:property [ rdfs:label "registration date" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q137375576> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:Date" ;
            sh:hasValue schema:Date ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path sdc4:xdtemporal-date ] ;
    sh:targetNode sdc4:mc-z72jnzdib9hi311s338zwdog ;
    sdc4-meta:sdcType "XdTemporalType" .

sdc4:mc-ouqi09d8kjqeojlr7vnclysj-shape a sh:NodeShape ;
    rdfs:label "Field of Study" ;
    rdfs:comment "Major field of study" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxLength 200 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ],
        [ rdfs:label "field of study" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1047113> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-ouqi09d8kjqeojlr7vnclysj ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:ClusterBaseShape a sh:NodeShape ;
    sh:property [ sh:message "Cluster can contain zero or more components" ;
            sh:minCount 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Cluster must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ] ;
    sh:targetClass sdc4:ClusterType .

sdc4:XdStringBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdString must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdString value must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:xdstring-value ],
        [ sh:datatype xsd:language ;
            sh:maxCount 1 ;
            sh:message "XdString language must be a valid language code" ;
            sh:minCount 0 ;
            sh:path sdc4:xdstring-language ] ;
    sh:targetClass sdc4:XdStringType .

sdc4:XdTemporalBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdTemporal must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:message "XdTemporal date must be a valid date" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-date ],
        [ sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:message "XdTemporal datetime must be a valid datetime" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-datetime ],
        [ sh:datatype xsd:time ;
            sh:maxCount 1 ;
            sh:message "XdTemporal time must be a valid time" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-time ],
        [ sh:datatype xsd:gYearMonth ;
            sh:maxCount 1 ;
            sh:message "XdTemporal year-month must be a valid gYearMonth" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-year-month ] ;
    sh:targetClass sdc4:XdTemporalType .

sdc4:XdTokenBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdToken must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:token ;
            sh:maxCount 1 ;
            sh:message "XdToken must have a token value" ;
            sh:minCount 1 ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetClass sdc4:XdTokenType .

