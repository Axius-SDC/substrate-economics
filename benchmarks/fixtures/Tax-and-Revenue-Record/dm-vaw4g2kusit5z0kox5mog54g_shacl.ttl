            sh:in ( "Employment" "Business Registry" "Property Registry" "Maritime" "Law Enforcement" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "Domain (computing) (Q7363)" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q7363> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-hh750k4i187bqzot5md216r1 ;
