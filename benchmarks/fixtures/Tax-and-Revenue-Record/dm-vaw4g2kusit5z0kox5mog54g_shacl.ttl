sdc4:mc-fqgaf7s7gkwi6j4hh88meudp-shape a sh:NodeShape ;
    rdfs:label "Payment Method" ;
    rdfs:comment "How the payment was made" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "payment method" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1912682> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ sh:datatype xsd:token ;
            sh:in ( "Bank Transfer" "Check" "Cash" "Payroll Deduction" ) ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetNode sdc4:mc-fqgaf7s7gkwi6j4hh88meudp ;
    sdc4-meta:sdcType "XdTokenType" .

