    sh:targetNode sdc4:mc-cuazcmxeeo8osfybrgdpe9g7 ;
    sdc4-meta:sdcType "XdTemporalType" .

sdc4:mc-ekmjsthf4vkzcff9pwodqg5n-shape a sh:NodeShape ;
