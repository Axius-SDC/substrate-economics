sdc4:mc-hh750k4i187bqzot5md216r1-shape a sh:NodeShape ;
    rdfs:label "Source Domain" ;
    rdfs:comment "The domain that generated this tax obligation" ;
    sh:node sdc4:XdTokenBaseShape ;
