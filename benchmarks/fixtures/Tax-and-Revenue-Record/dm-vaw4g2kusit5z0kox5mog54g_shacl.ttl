sdc4:mc-a2yks4n49m6gcgpa7qc9hyg1-shape a sh:NodeShape ;
    rdfs:label "Filing ID" ;
    rdfs:comment "Unique identifier for this tax filing" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "Identification Type" ;
            sh:hasValue <http://release.niem.gov/niem/niem-core/5.0/niem-core.owl#IdentificationType> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:identifier" ;
            sh:hasValue schema:identifier ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:string ;
            sh:maxLength 50 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ] ;
    sh:targetNode sdc4:mc-a2yks4n49m6gcgpa7qc9hyg1 ;
    sdc4-meta:sdcType "XdStringType" .

