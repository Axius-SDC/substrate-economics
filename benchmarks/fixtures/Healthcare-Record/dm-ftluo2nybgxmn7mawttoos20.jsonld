  "components": [
    {
      "@type": "ClusterType",
      "@id": "sdc4:mc-ygtbvvmzcw3ukfsg3axqry97",
      "label": "Patient Record",
      "description": "A person's medical record in the Cordova healthcare system.\nBusiness Context: Links to Civil Registry via National ID. All clinical cells carry Restricted:PatientCare policy.\nPurpose: Comprehensive medical record for a Cordova resident",
      "cardinality": {
        "minOccurs": 0,
        "maxOccurs": 1
      },
      "contains": [
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-nj7s1gk45tfgyooxpz0qaha3",
          "label": "National ID (CID)",
          "description": "Cordova National Identity Number. Format: COR-PPCC-NNNNNN where PP is the two-letter province code (AL=Aldara, BR=Brevina, CE=Celara), CC is the two-digit city code (01-03), and NNNNNN is a six-digit sequence number. Issued at birth or naturalization. Required for all government transactions.",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "http://schema.org/identifier"
            },
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "https://www.wikidata.org/wiki/Q1140371"
            },
            {
              "predicate": "skos:broadMatch",
              "object": "https://schema.org/identifier"
            }
          ]
        },
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-jz2hqntyol8lopw6q6zdud78",
          "label": "Medical Record Number",
          "description": "Institution-specific medical record number for linking to clinical records",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "constraints": {
            "minLength": 1,
            "maxLength": 50
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "https://uts.nlm.nih.gov/uts/umls/concept/C1301894"
            },
            {
              "predicate": "rdf:type",
              "object": "https://schema.org/Text"
            }
          ]
        }
