        [ rdfs:label "Body temperature (observable entity)" ;
            sh:hasValue <http://snomed.info/id/386725007> ;
            sh:path skos:exactMatch ],
        [ rdfs:label "body temperature" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1066998> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "Body temperature LOINC 8310-5" ;
            sh:hasValue <https://loinc.org/8310-5/> ;
            sh:path rdfs:seeAlso ],
        [ sh:node sdc4:SimpleReferenceRangeBaseShape ;
            sh:path sdc4-meta:hasSimpleReferenceRange ],
        [ rdfs:label "Body Temperature (Clinical Methods)" ;
            sh:hasValue <https://www.ncbi.nlm.nih.gov/books/NBK331/> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node sdc4:mc-ihugcgyqyfjp3u9y5qva1fwz-shape ;
            sh:path sdc4-meta:hasUnit ] ;
    sh:targetNode sdc4:mc-b5zse0kmvpkj74ggqvgk647l ;
    sdc4-meta:sdcType "XdQuantityType" .

