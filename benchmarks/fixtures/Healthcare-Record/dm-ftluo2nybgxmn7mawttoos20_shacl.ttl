sdc4:DMBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-label ],
        [ sh:datatype xsd:language ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify a language" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-language ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify encoding" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-encoding ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a mandatory instance_id (CUID2)" ;
            sh:minCount 1 ;
            sh:path sdc4:instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_version_id ] ;
    sh:targetClass sdc4:DMType .

sdc4:mc-07osold8ovbjsqzvz00f3ked2-shape a sh:NodeShape ;
    rdfs:label "Severity (3-Point)" ;
    rdfs:comment "Three-point severity scale for clinical findings" ;
    sh:node sdc4:XdOrdinalBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ sh:in ( "0" "1" "2" ) ;
            sh:path sdc4:xdordinal-value ],
        [ sh:in ( "Mild" "Moderate" "Severe" ) ;
            sh:path sdc4:xdordinal-symbol ],
        [ rdfs:label "severity" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q10870002> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ] ;
    sh:targetNode sdc4:mc-07osold8ovbjsqzvz00f3ked2 ;
    sdc4-meta:sdcType "XdOrdinalType" .

sdc4:mc-b5zse0kmvpkj74ggqvgk647l-shape a sh:NodeShape ;
    rdfs:label "Body Temperature" ;
    rdfs:comment "Patient body temperature measured in degrees Celsius during a clinical visit. Normal adult range is 36.1–37.2°C. Triage screening vital sign." ;
