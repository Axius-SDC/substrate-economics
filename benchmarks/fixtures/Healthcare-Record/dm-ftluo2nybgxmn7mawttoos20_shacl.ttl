sdc4:ReferenceRangeBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "ReferenceRange must have a meaning" ;
            sh:minCount 1 ;
            sh:path sdc4:range-meaning ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:message "ReferenceRange lower bound must be a decimal" ;
            sh:minCount 0 ;
            sh:path sdc4:range-lower ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:message "ReferenceRange upper bound must be a decimal" ;
