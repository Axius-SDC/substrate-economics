            sh:minCount 1 ;
            sh:node sdc4:mc-y28mhe3jdzi9b8ztn3fxodtf-shape ;
            sh:path sdc4-meta:hasUnit ] ;
    sh:targetNode sdc4:mc-xccdfbmuqcy5yzv2n6ef0hrs ;
