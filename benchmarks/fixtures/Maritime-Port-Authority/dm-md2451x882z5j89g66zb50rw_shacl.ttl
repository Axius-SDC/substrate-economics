sdc4:mc-cl1hiqht7tm42a8lh8c4c1hz-shape a sh:NodeShape ;
    rdfs:label "Vessel MMSI" ;
    rdfs:comment "Maritime Mobile Service Identity (MMSI) number" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxLength 9 ;
            sh:minLength 9 ;
            sh:path sdc4:xdstring-value ;
            sh:pattern "\\d{9}" ],
        [ rdfs:label "Maritime Mobile Service Identity" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1795701> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-cl1hiqht7tm42a8lh8c4c1hz ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-dp1dkn09vydj2ss6ho37kyhv-shape a sh:NodeShape ;
    rdfs:label "Customs Reference Number" ;
    rdfs:comment "Customs filing reference number" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxLength 50 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ],
