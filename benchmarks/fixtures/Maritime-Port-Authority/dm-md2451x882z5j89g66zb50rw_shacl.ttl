            sh:maxCount 1 ;
            sh:message "XdFile media type must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:xdfile-media-type ] ;
    sh:targetClass sdc4:XdFileType .

sdc4:XdFloatBaseShape a sh:NodeShape ;
