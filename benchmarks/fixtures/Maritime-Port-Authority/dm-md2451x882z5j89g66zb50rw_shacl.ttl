sdc4:DMBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-label ],
        [ sh:datatype xsd:language ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify a language" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-language ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify encoding" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-encoding ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a mandatory instance_id (CUID2)" ;
            sh:minCount 1 ;
            sh:path sdc4:instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_version_id ] ;
    sh:targetClass sdc4:DMType .

sdc4:mc-an9kafb2l1enwh20ngvo1n7y-shape a sh:NodeShape ;
    rdfs:label "Cargo Destination" ;
    rdfs:comment "Final destination for this cargo (may be Porto Sereno or transshipment)" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "delivery point" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q5254083> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:description" ;
            sh:hasValue schema:description ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:string ;
            sh:maxLength 200 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ] ;
    sh:targetNode sdc4:mc-an9kafb2l1enwh20ngvo1n7y ;
    sdc4-meta:sdcType "XdStringType" .

