            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-dp1dkn09vydj2ss6ho37kyhv ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-e92ud8io69rm826g9b1jrrgh-shape a sh:NodeShape ;
    rdfs:label "Port Fee Amount" ;
    rdfs:comment "Fee amount assessed for port services in Cordova Córdoba. Includes berth rental, pilotage, tug assistance, waste disposal, and other harbor charges per the Porto Sereno fee schedule." ;
    sh:node sdc4:XdQuantityBaseShape ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:minInclusive 0.00000 ;
            sh:path sdc4:xdquantity-value ;
            sdc4-meta:fractionDigits 2 ;
            sdc4-meta:totalDigits 12 ],
        [ rdfs:label "MonetaryValue (QUDT QuantityKind)" ;
            sh:hasValue <http://qudt.org/vocab/quantitykind/Currency> ;
            sh:path skos:broadMatch ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node sdc4:mc-u18l77xlj2omcbmnpi5j7fff-shape ;
            sh:path sdc4-meta:hasUnit ],
        [ rdfs:label "port charges" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1194642> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:SimpleReferenceRangeBaseShape ;
            sh:path sdc4-meta:hasSimpleReferenceRange ],
        [ rdfs:label "MonetaryAmount" ;
            sh:hasValue schema:MonetaryAmount ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-e92ud8io69rm826g9b1jrrgh ;
    sdc4-meta:sdcType "XdQuantityType" .

