        [ sh:datatype xsd:decimal ;
            sh:maxInclusive 30.00000 ;
            sh:minInclusive 0.50000 ;
            sh:path sdc4:xdquantity-value ;
            sdc4-meta:fractionDigits 2 ;
            sdc4-meta:totalDigits 5 ],
        [ rdfs:label "IMO Tonnage Measurement Convention" ;
            sh:hasValue <https://www.imo.org/en/about/conventions/pages/international-convention-on-tonnage-measurement-of-ships.aspx> ;
