        [ sh:node sdc4:mc-vzabxfc733qk7lo1knaggxfs-shape ;
            sh:order 8 ;
            sh:path sdc4:hasCluster ],
        [ sh:node sdc4:mc-tb3wwfwects1a6ap4ro7z5s8-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "employment record book" ;
