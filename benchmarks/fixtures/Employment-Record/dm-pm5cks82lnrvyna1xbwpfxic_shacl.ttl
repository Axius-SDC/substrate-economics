        [ rdfs:label "schema:Date" ;
            sh:hasValue schema:Date ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path sdc4:xdtemporal-date ] ;
    sh:targetNode sdc4:mc-el43lwc0fnamy0v0ocub38t7 ;
    sdc4-meta:sdcType "XdTemporalType" .

sdc4:mc-ghsjyyzudma3eq761dwd4j9p-shape a sh:NodeShape ;
    rdfs:label "Start Date" ;
    rdfs:comment "Date employment began" ;
    sh:node sdc4:XdTemporalBaseShape ;
    sh:property [ rdfs:label "schema:Date" ;
            sh:hasValue schema:Date ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
