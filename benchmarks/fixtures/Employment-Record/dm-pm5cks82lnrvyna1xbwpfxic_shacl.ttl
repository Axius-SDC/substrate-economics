        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a mandatory instance_id (CUID2)" ;
            sh:minCount 1 ;
            sh:path sdc4:instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_version_id ] ;
    sh:targetClass sdc4:DMType .

