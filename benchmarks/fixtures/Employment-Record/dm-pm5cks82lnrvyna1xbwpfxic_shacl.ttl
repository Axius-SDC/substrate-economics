        [ sh:datatype xsd:string ;
            sh:maxLength 200 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ],
        [ rdfs:label "department" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q2366457> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-bbu03oqjkniydmzb7pqcjg3m ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-el43lwc0fnamy0v0ocub38t7-shape a sh:NodeShape ;
    rdfs:label "End Date" ;
    rdfs:comment """Date employment ended. Null for current positions.

---""" ;
    sh:node sdc4:XdTemporalBaseShape ;
    sh:property [ rdfs:label "termination date" ;
