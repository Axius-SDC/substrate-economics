sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape a sh:NodeShape ;
    rdfs:label "City" ;
    rdfs:comment "One of the nine cities in the Republic of Cordova." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "City" ;
            sh:hasValue <http://schema.org/City> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Porto Sereno" "Vistamar" "Rioseco" "Campoluz" "Tierraverde" "Montecara" "Novaciudad" "Piedrasol" "Lagunavista" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-atdtdfzruh7tya0iv5cz365l ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-aw74ticc3fnjkz4vk4b03jr6-shape a sh:NodeShape ;
    rdfs:label "Salary Amount" ;
    rdfs:comment "Monthly gross salary or wage in Cordova Córdoba. Represents the agreed compensation amount before deductions for taxes, social security, and other withholdings." ;
    sh:node sdc4:XdQuantityBaseShape ;
    sh:property [ rdfs:label "salary" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q178848> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:SimpleReferenceRangeBaseShape ;
            sh:path sdc4-meta:hasSimpleReferenceRange ],
        [ sh:datatype xsd:decimal ;
            sh:minInclusive 0.00000 ;
            sh:path sdc4:xdquantity-value ;
            sdc4-meta:fractionDigits 2 ;
            sdc4-meta:totalDigits 12 ],
        [ rdfs:label "MonetaryAmount" ;
            sh:hasValue schema:MonetaryAmount ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "MonetaryValue (QUDT QuantityKind)" ;
            sh:hasValue <http://qudt.org/vocab/quantitykind/Currency> ;
            sh:path skos:broadMatch ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node sdc4:mc-u18l77xlj2omcbmnpi5j7fff-shape ;
            sh:path sdc4-meta:hasUnit ] ;
    sh:targetNode sdc4:mc-aw74ticc3fnjkz4vk4b03jr6 ;
    sdc4-meta:sdcType "XdQuantityType" .

sdc4:mc-bbu03oqjkniydmzb7pqcjg3m-shape a sh:NodeShape ;
    rdfs:label "Department" ;
    rdfs:comment "Department or division within the employer organization" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "schema:description" ;
