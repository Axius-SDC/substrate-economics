sdc4:mc-ftuxt5nrrffwjb2vymn80yx2-shape a sh:NodeShape ;
    rdfs:label "Manner of Death" ;
    rdfs:comment "Manner in which death occurred" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "manner of death" ;
