            sh:path rdf:type ],
        [ rdfs:label "full name" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1071027> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 100 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ] ;
    sh:targetNode sdc4:mc-pmw2cq7fioqlbs2ljdh34rkn ;
    sdc4-meta:sdcType "XdStringType" .

