sdc4:mc-mw9qdn71urog8egjbp5t3y00-shape a sh:NodeShape ;
    rdfs:label "Sex" ;
    rdfs:comment "Biological sex assigned at birth based on physical characteristics. UMLS CUI: C0079399 (Biologic Sex). Aligned with OMB standards for reporting." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ sh:datatype xsd:token ;
            sh:in ( "Male" "Female" "Intersex" "Unknown" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "Biological sex" ;
            sh:hasValue <https://uts.nlm.nih.gov/uts/umls/concept/C5236503> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "skos:ConceptScheme" ;
