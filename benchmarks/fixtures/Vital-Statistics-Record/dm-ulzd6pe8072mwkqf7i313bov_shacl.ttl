sdc4:dm-ulzd6pe8072mwkqf7i313bov-shape a sh:NodeShape ;
    rdfs:label "Vital Statistics Record" ;
    dc:coverage "Universal" ;
    dc:language "en-US" ;
    dc:rights "CC-BY http://creativecommons.org/licenses/by/3.0/" ;
    rdfs:comment "Maintain the authoritative registry of life events in Cordova." ;
    sh:node sdc4:DMBaseShape ;
    sh:property [ sh:maxCount 1 ;
            sh:message "Data Model must have a root data Cluster" ;
            sh:minCount 1 ;
            sh:node sdc4:mc-tard9hhq13m95hinbh4h7k5j-shape ;
            sh:path sdc4:dm-data ] ;
    sh:targetNode sdc4:dm-ulzd6pe8072mwkqf7i313bov ;
    sdc4:dm-encoding "utf-8" ;
    sdc4:dm-language "en-US" ;
    sdc4-meta:generatedAt "2026-03-08T03:30:16.612948+00:00"^^xsd:dateTime .

sdc4:DMBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-label ],
        [ sh:datatype xsd:language ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify a language" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-language ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify encoding" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-encoding ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a mandatory instance_id (CUID2)" ;
            sh:minCount 1 ;
            sh:path sdc4:instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_version_id ] ;
    sh:targetClass sdc4:DMType .

sdc4:mc-ajfsyoyrz38094hswxh13i3x-shape a sh:NodeShape ;
    rdfs:label "Certificate Number" ;
    rdfs:comment "Unique certificate number for this vital record" ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "schema:identifier" ;
            sh:hasValue schema:identifier ;
            sh:path skos:broadMatch ],
        [ rdfs:label "Register of Practitioners registration number" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q108891191> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 50 ;
            sh:minLength 1 ;
            sh:path sdc4:xdstring-value ] ;
    sh:targetNode sdc4:mc-ajfsyoyrz38094hswxh13i3x ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape a sh:NodeShape ;
    rdfs:label "City" ;
    rdfs:comment "One of the nine cities in the Republic of Cordova." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "City" ;
            sh:hasValue <http://schema.org/City> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Porto Sereno" "Vistamar" "Rioseco" "Campoluz" "Tierraverde" "Montecara" "Novaciudad" "Piedrasol" "Lagunavista" ) ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetNode sdc4:mc-atdtdfzruh7tya0iv5cz365l ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-az8kem3v58y9zenys7mthqxe-shape a sh:NodeShape ;
    rdfs:label "Birth Record" ;
    rdfs:comment """Details specific to birth certificates.
Business Context: Links newborn and parents to Civil Registry, physician to Healthcare
Purpose: Document a birth with parents, attending physician, and location
Parent Cluster: Vital Event""" ;
    sh:node sdc4:ClusterBaseShape ;
    sh:property [ rdfs:label "WHO Civil Registration and Vital Statistics" ;
            sh:hasValue <https://www.who.int/data/data-collection-tools/civil-registration-and-vital-statistics-(crvs)> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "birth certificate" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q83900> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-nj7s1gk45tfgyooxpz0qaha3-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-mw9qdn71urog8egjbp5t3y00-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-pmw2cq7fioqlbs2ljdh34rkn-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "schema:ItemList" ;
            sh:hasValue schema:ItemList ;
            sh:path skos:broadMatch ] ;
    sh:targetNode sdc4:mc-az8kem3v58y9zenys7mthqxe .

sdc4:mc-chtyne5i6qcwbrby29vbuh2k-shape a sh:NodeShape ;
    rdfs:label "Marriage Record" ;
    rdfs:comment """Details specific to marriage certificates.
Business Context: Links both parties to Civil Registry identities
Purpose: Document a marriage with both parties, officiant, and witnesses
Parent Cluster: Vital Event""" ;
    sh:node sdc4:ClusterBaseShape ;
    sh:property [ rdfs:label "schema:ItemList" ;
            sh:hasValue schema:ItemList ;
            sh:path skos:broadMatch ],
        [ rdfs:label "marriage certificate" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q1299632> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-pmw2cq7fioqlbs2ljdh34rkn-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "WHO Civil Registration and Vital Statistics" ;
            sh:hasValue <https://www.who.int/data/data-collection-tools/civil-registration-and-vital-statistics-(crvs)> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-nj7s1gk45tfgyooxpz0qaha3-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ] ;
    sh:targetNode sdc4:mc-chtyne5i6qcwbrby29vbuh2k .

sdc4:mc-dsoyfaplxw8ide1opo5w8fxg-shape a sh:NodeShape ;
    rdfs:label "Place of Death" ;
    rdfs:comment "Type of location where death occurred" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "place of death" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q18658526> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ sh:datatype xsd:token ;
            sh:in ( "Hospital" "Residence" "Other" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-dsoyfaplxw8ide1opo5w8fxg ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-e3sfb43zh1vjlgceb5guh0mj-shape a sh:NodeShape ;
    rdfs:label "Event Date" ;
    rdfs:comment "Date the vital event occurred" ;
    sh:node sdc4:XdTemporalBaseShape ;
    sh:property [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:path sdc4:xdtemporal-date ],
        [ rdfs:label "valid time" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q7911665> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:Date" ;
            sh:hasValue schema:Date ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:gYearMonth ;
            sh:maxCount 1 ;
            sh:path sdc4:xdtemporal-year-month ] ;
    sh:targetNode sdc4:mc-e3sfb43zh1vjlgceb5guh0mj ;
    sdc4-meta:sdcType "XdTemporalType" .

sdc4:mc-ft4kk6m3r1goxkte0d7wflk8-shape a sh:NodeShape ;
    rdfs:label "Decree Date" ;
    rdfs:comment "Date the divorce decree was issued by the court" ;
