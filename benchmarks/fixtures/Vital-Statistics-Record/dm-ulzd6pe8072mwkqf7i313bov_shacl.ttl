        [ sh:datatype xsd:token ;
            sh:in ( "Natural" "Accident" "Homicide" "Suicide" "Undetermined" "Pending Investigation" ) ;
            sh:path sdc4:xdtoken-value ] ;
    sh:targetNode sdc4:mc-ftuxt5nrrffwjb2vymn80yx2 ;
