            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:message "XdTemporal date must be a valid date" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-date ],
        [ sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:message "XdTemporal datetime must be a valid datetime" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-datetime ],
        [ sh:datatype xsd:time ;
            sh:maxCount 1 ;
            sh:message "XdTemporal time must be a valid time" ;
            sh:minCount 0 ;
            sh:path sdc4:xdtemporal-time ],
