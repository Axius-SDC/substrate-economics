  "label": "Property Registry",
  "description": "Maintain the authoritative registry of land and property ownership in Cordova.",
  "metadata": {
    "dc:title": "Property Registry",
    "dc:creator": "Timothy Cook",
    "dc:description": "Maintain the authoritative registry of land and property ownership in Cordova.",
