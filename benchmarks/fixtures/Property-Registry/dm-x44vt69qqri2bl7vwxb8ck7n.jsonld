  },
  "components": [
    {
      "@type": "ClusterType",
      "@id": "sdc4:mc-bgc4n3424bzb8gpgnjhxxha9",
      "label": "Property Record",
      "description": "A registered land parcel or property in Cordova.\nBusiness Context: Links to Civil Registry (person owners) and Business Registry (business owners)\nPurpose: Document a property with location, type, and current ownership",
      "cardinality": {
        "minOccurs": 0,
        "maxOccurs": 1
      },
      "contains": [
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-hs7197k4s33eg7wbspgudu4u",
          "label": "Parcel Number",
          "description": "Cordova property parcel identifier. Format: PP-CC-NNNNNN where PP is the province code, CC is the city code, and NNNNNN is a parcel sequence number.",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "http://schema.org/identifier"
            },
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "https://www.wikidata.org/wiki/Q47161795"
            },
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "https://www.wikidata.org/wiki/Q66502406"
            },
            {
              "predicate": "skos:broadMatch",
              "object": "https://schema.org/identifier"
            }
          ]
        },
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-l338k7nlvnq2am0owa19yxfc",
          "label": "Address (Line 1)",
          "description": "Street address line, building/apartment number, or P.O. Box number.",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "constraints": {
            "maxLength": 200
          },
          "dataType": "xsd:string",
          "semanticLinks": [
            {
              "predicate": "rdf:type",
              "object": "https://schema.org/Text"
            },
            {
              "predicate": "rdfs:isDefinedBy",
              "object": "https://schema.org/streetAddress"
            }
          ]
        },
        {
          "@type": "XdStringType",
          "@id": "sdc4:mc-ek5h6dsqpd9kz0l4mcckmxpt",
          "label": "Address (Line 2)",
          "description": "Street address line, building/apartment number, or P.O. Box number.",
          "cardinality": {
            "minOccurs": 0,
            "maxOccurs": 1
          },
          "constraints": {
            "maxLength": 200
          },
          "dataType": "xsd:string",
