            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-vdf0oczbk8uxsm2le09l27ke-shape ;
            sh:order 11 ;
            sh:path sdc4:hasCluster ],
        [ rdfs:label "schema:ItemList" ;
            sh:hasValue schema:ItemList ;
            sh:path skos:broadMatch ],
        [ sh:node sdc4:mc-tjkw46wy20kstzgg1y60clxx-shape ;
            sh:order 9 ;
            sh:path sdc4:hasCluster ],
        [ sh:node sdc4:mc-vo9jtmexkaaol3y657fm0xn8-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "NIEM Open Standard" ;
            sh:hasValue <https://niemopen.org/> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-kv5qqs3o4jwcwz9javgw1pzh-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-l79ua955rihnjbrxyhu7z5ac-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "property record" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q66502406> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:mc-cexrgb7uy29kn6w27tpmujtv-shape ;
            sh:order 10 ;
            sh:path sdc4:hasCluster ],
        [ sh:node sdc4:mc-xtljf8q6rfyfewdkgu4e5ouj-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-ek5h6dsqpd9kz0l4mcckmxpt-shape ;
