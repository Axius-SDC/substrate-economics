sdc4:mc-cexrgb7uy29kn6w27tpmujtv-shape a sh:NodeShape ;
    rdfs:label "Property Value Assessment" ;
    rdfs:comment """Property value assessment for tax purposes.
Purpose: Record assessed values that link to Tax & Revenue for property tax filings
Parent Cluster: Property Record""" ;
    sh:node sdc4:ClusterBaseShape ;
    sh:property [ sh:node sdc4:mc-j3y76yob1s958dry2d551tew-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ rdfs:label "assessment" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q851176> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:ItemList" ;
            sh:hasValue schema:ItemList ;
            sh:path skos:broadMatch ],
        [ sh:node sdc4:mc-rbq2sjcb8h284c8dnzjdna5h-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ],
        [ sh:node sdc4:mc-hlg1jmx1v9t4zkq16c1i66bg-shape ;
            sh:order 0 ;
            sh:path sdc4:hasComponent ] ;
    sh:targetNode sdc4:mc-cexrgb7uy29kn6w27tpmujtv .

sdc4:mc-cy92p3uebrmjf191wcs07t3o-shape a sh:NodeShape ;
    rdfs:label "Lien Type" ;
    rdfs:comment "Type of lien or encumbrance" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ sh:datatype xsd:token ;
            sh:in ( "Mortgage" "Tax Lien" "Judgment Lien" "Mechanic's Lien" "Easement" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "Lien Type" ;
            sh:hasValue <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Agreements/LienType> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-cy92p3uebrmjf191wcs07t3o ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-da261k0tox4747gnkmmek15i-shape a sh:NodeShape ;
    rdfs:label "Lien Amount" ;
    rdfs:comment "Monetary value of the lien or encumbrance recorded against the property in Cordova Córdoba. Represents the outstanding obligation secured by the property." ;
    sh:node sdc4:XdQuantityBaseShape ;
    sh:property [ rdfs:label "lien" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q4469383> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:node sdc4:SimpleReferenceRangeBaseShape ;
            sh:path sdc4-meta:hasSimpleReferenceRange ],
        [ rdfs:label "MonetaryAmount" ;
            sh:hasValue schema:MonetaryAmount ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "MonetaryValue (QUDT QuantityKind)" ;
            sh:hasValue <http://qudt.org/vocab/quantitykind/Currency> ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:decimal ;
            sh:minInclusive 0.00000 ;
            sh:path sdc4:xdquantity-value ;
            sdc4-meta:fractionDigits 2 ;
            sdc4-meta:totalDigits 14 ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node sdc4:mc-u18l77xlj2omcbmnpi5j7fff-shape ;
            sh:path sdc4-meta:hasUnit ] ;
    sh:targetNode sdc4:mc-da261k0tox4747gnkmmek15i ;
    sdc4-meta:sdcType "XdQuantityType" .

sdc4:mc-ek5h6dsqpd9kz0l4mcckmxpt-shape a sh:NodeShape ;
    rdfs:label "Address (Line 2)" ;
    rdfs:comment "Street address line, building/apartment number, or P.O. Box number." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxLength 200 ;
            sh:path sdc4:xdstring-value ],
        [ rdfs:label "schema:Text" ;
            sh:hasValue schema:Text ;
            sh:path rdf:type ],
        [ rdfs:label "Street Address" ;
            sh:hasValue schema:streetAddress ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-ek5h6dsqpd9kz0l4mcckmxpt ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-f53n973eb8d9qrnnp9atw8eu-shape a sh:NodeShape ;
    rdfs:label "Square Meters" ;
    rdfs:comment "SI derived unit of area. Used for land parcels and property assessments in the Cordova property registry." ;
    sh:node sdc4:UnitsBaseShape ;
    sh:property [ rdfs:label "Square Metre (QUDT)" ;
            sh:hasValue <http://qudt.org/vocab/unit/M2> ;
            sh:path owl:sameAs ],
        [ rdfs:label "Area (QUDT QuantityKind)" ;
            sh:hasValue <http://qudt.org/vocab/quantitykind/Area> ;
            sh:path rdfs:seeAlso ],
        [ rdfs:label "square metre" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q25343> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-f53n973eb8d9qrnnp9atw8eu ;
    sdc4-meta:sdcType "UnitsType" .

sdc4:mc-hlg1jmx1v9t4zkq16c1i66bg-shape a sh:NodeShape ;
    rdfs:label "Assessed Value" ;
    rdfs:comment "Government-determined market value of the property in Cordova Córdoba. Used as the basis for property tax calculation by the Cordova Tax Authority." ;
    sh:node sdc4:XdQuantityBaseShape ;
    sh:property [ sh:node sdc4:SimpleReferenceRangeBaseShape ;
            sh:path sdc4-meta:hasSimpleReferenceRange ],
        [ sh:datatype xsd:decimal ;
            sh:minInclusive 0.00000 ;
            sh:path sdc4:xdquantity-value ;
            sdc4-meta:fractionDigits 2 ;
            sdc4-meta:totalDigits 14 ],
        [ rdfs:label "MonetaryValue (QUDT QuantityKind)" ;
            sh:hasValue <http://qudt.org/vocab/quantitykind/Currency> ;
            sh:path skos:broadMatch ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node sdc4:mc-u18l77xlj2omcbmnpi5j7fff-shape ;
            sh:path sdc4-meta:hasUnit ],
        [ rdfs:label "MonetaryAmount" ;
            sh:hasValue schema:MonetaryAmount ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "real estate appraisal" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q512599> ;
            sh:path rdfs:isDefinedBy ] ;
    sh:targetNode sdc4:mc-hlg1jmx1v9t4zkq16c1i66bg ;
    sdc4-meta:sdcType "XdQuantityType" .

sdc4:mc-hs7197k4s33eg7wbspgudu4u-shape a sh:NodeShape ;
    rdfs:label "Parcel Number" ;
    rdfs:comment "Cordova property parcel identifier. Format: PP-CC-NNNNNN where PP is the province code, CC is the city code, and NNNNNN is a parcel sequence number." ;
    sh:node sdc4:XdStringBaseShape ;
    sh:property [ rdfs:label "property record" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q66502406> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "National Register property and resource category" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q47161795> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:string ;
            sh:maxLength 12 ;
            sh:minLength 12 ;
            sh:path sdc4:xdstring-value ;
            sh:pattern "(AL|BR|CE)-0[1-3]-[0-9]{6}" ],
        [ rdfs:label "identifier" ;
            sh:hasValue <http://schema.org/identifier> ;
            sh:path rdfs:isDefinedBy ],
        [ rdfs:label "schema:identifier" ;
            sh:hasValue schema:identifier ;
            sh:path skos:broadMatch ] ;
    sh:targetNode sdc4:mc-hs7197k4s33eg7wbspgudu4u ;
    sdc4-meta:sdcType "XdStringType" .

sdc4:mc-j3y76yob1s958dry2d551tew-shape a sh:NodeShape ;
    rdfs:label "Assessment Status" ;
    rdfs:comment "Status of the assessment" ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ],
        [ rdfs:label "ActionStatusType" ;
            sh:hasValue <http://schema.org/ActionStatusType> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Final" "Under Appeal" "Preliminary" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ] ;
    sh:targetNode sdc4:mc-j3y76yob1s958dry2d551tew ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-j8gn6xsrzbnzkqlnpk2dkwam-shape a sh:NodeShape ;
    rdfs:label "Transfer Amount" ;
    rdfs:comment "Sale price or transfer value of the property transaction in Cordova Córdoba. Recorded at the time of ownership transfer for tax and registry purposes." ;
    sh:node sdc4:XdQuantityBaseShape ;
    sh:property [ rdfs:label "MonetaryValue (QUDT QuantityKind)" ;
            sh:hasValue <http://qudt.org/vocab/quantitykind/Currency> ;
            sh:path skos:broadMatch ],
        [ sh:datatype xsd:decimal ;
            sh:minInclusive 0.00000 ;
            sh:path sdc4:xdquantity-value ;
            sdc4-meta:fractionDigits 2 ;
            sdc4-meta:totalDigits 14 ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node sdc4:mc-u18l77xlj2omcbmnpi5j7fff-shape ;
            sh:path sdc4-meta:hasUnit ],
        [ rdfs:label "real estate transaction" ;
            sh:hasValue <https://www.wikidata.org/wiki/Q56139218> ;
