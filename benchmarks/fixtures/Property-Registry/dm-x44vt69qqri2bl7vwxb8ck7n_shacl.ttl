@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sdc4:AttestationBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Attestation view must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:attestation-view ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Attestation proof must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:attestation-proof ] ;
    sh:targetClass sdc4:AttestationType .

sdc4:AuditBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:message "Audit must have a timestamp" ;
            sh:minCount 1 ;
            sh:path sdc4:audit-time ],
        [ sh:class sdc4:PartyType ;
            sh:maxCount 1 ;
            sh:message "Audit committer must be a Party" ;
            sh:minCount 0 ;
            sh:path sdc4:audit-committer ] ;
    sh:targetClass sdc4:AuditType .

sdc4:ParticipationBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Participation function must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:participation-function ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Participation mode must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:participation-mode ] ;
    sh:targetClass sdc4:ParticipationType .

sdc4:PartyBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Party must have a name" ;
            sh:minCount 1 ;
            sh:path sdc4:party-name ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Party ID must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:party-id ] ;
    sh:targetClass sdc4:PartyType .

sdc4:ReferenceRangeBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "ReferenceRange must have a meaning" ;
            sh:minCount 1 ;
            sh:path sdc4:range-meaning ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:message "ReferenceRange lower bound must be a decimal" ;
            sh:minCount 0 ;
            sh:path sdc4:range-lower ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:message "ReferenceRange upper bound must be a decimal" ;
            sh:minCount 0 ;
            sh:path sdc4:range-upper ] ;
    sh:targetClass sdc4:ReferenceRangeType .

sdc4:SDC4ComponentShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "All SDC4 components must have a label" ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:class rdfs:Class ;
            sh:message "All SDC4 components must have an rdf:type" ;
            sh:minCount 1 ;
            sh:path rdf:type ] ;
    sh:targetClass rdfs:Class .

sdc4:XdBooleanBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdBoolean must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:message "XdBoolean must have a boolean value" ;
            sh:minCount 1 ;
            sh:path sdc4:xdboolean-value ] ;
    sh:targetClass sdc4:XdBooleanType .

sdc4:XdCountBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdCount must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:message "XdCount must have an integer value" ;
            sh:minCount 1 ;
            sh:path sdc4:xdcount-value ],
        [ sh:class sdc4:UnitsType ;
            sh:maxCount 1 ;
            sh:message "XdCount requires a Units component" ;
            sh:minCount 1 ;
            sh:path sdc4-meta:hasUnit ] ;
    sh:targetClass sdc4:XdCountType .

sdc4:XdDoubleBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdDouble must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:double ;
            sh:maxCount 1 ;
            sh:message "XdDouble must have a double value" ;
            sh:minCount 1 ;
            sh:path sdc4:xddouble-value ],
        [ sh:class sdc4:UnitsType ;
            sh:maxCount 1 ;
            sh:message "XdDouble requires a Units component" ;
            sh:minCount 1 ;
            sh:path sdc4-meta:hasUnit ] ;
    sh:targetClass sdc4:XdDoubleType .

sdc4:XdFileBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdFile must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:anyURI ;
            sh:maxCount 1 ;
            sh:message "XdFile must have a valid URI" ;
            sh:minCount 1 ;
            sh:path sdc4:xdfile-uri ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdFile media type must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:xdfile-media-type ] ;
    sh:targetClass sdc4:XdFileType .

sdc4:XdFloatBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdFloat must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:float ;
            sh:maxCount 1 ;
            sh:message "XdFloat must have a float value" ;
            sh:minCount 1 ;
            sh:path sdc4:xdfloat-value ],
        [ sh:class sdc4:UnitsType ;
            sh:maxCount 1 ;
            sh:message "XdFloat requires a Units component" ;
            sh:minCount 1 ;
            sh:path sdc4-meta:hasUnit ] ;
    sh:targetClass sdc4:XdFloatType .

sdc4:XdIntervalBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdInterval must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:maxCount 1 ;
            sh:message "XdInterval lower bound is optional" ;
            sh:minCount 0 ;
            sh:path sdc4:xdinterval-lower ],
        [ sh:maxCount 1 ;
            sh:message "XdInterval upper bound is optional" ;
            sh:minCount 0 ;
            sh:path sdc4:xdinterval-upper ] ;
    sh:targetClass sdc4:XdIntervalType .

sdc4:XdLinkBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdLink must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:anyURI ;
            sh:maxCount 1 ;
            sh:message "XdLink must have a valid URI" ;
            sh:minCount 1 ;
            sh:path sdc4:xdlink-url ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdLink relation must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:xdlink-relation ] ;
    sh:targetClass sdc4:XdLinkType .

sdc4:XdOrdinalBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdOrdinal must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:label ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:message "XdOrdinal must have an integer value" ;
            sh:minCount 1 ;
            sh:path sdc4:xdordinal-value ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "XdOrdinal symbol must be a string" ;
            sh:minCount 0 ;
            sh:path sdc4:xdordinal-symbol ] ;
    sh:targetClass sdc4:XdOrdinalType .

sdc4:dm-x44vt69qqri2bl7vwxb8ck7n-shape a sh:NodeShape ;
    rdfs:label "Property Registry" ;
    dc:coverage "Universal" ;
    dc:language "en-US" ;
    dc:rights "CC-BY http://creativecommons.org/licenses/by/3.0/" ;
    rdfs:comment "Maintain the authoritative registry of land and property ownership in Cordova." ;
    sh:node sdc4:DMBaseShape ;
    sh:property [ sh:maxCount 1 ;
            sh:message "Data Model must have a root data Cluster" ;
            sh:minCount 1 ;
            sh:node sdc4:mc-bgc4n3424bzb8gpgnjhxxha9-shape ;
            sh:path sdc4:dm-data ] ;
    sh:targetNode sdc4:dm-x44vt69qqri2bl7vwxb8ck7n ;
    sdc4:dm-encoding "utf-8" ;
    sdc4:dm-language "en-US" ;
    sdc4-meta:generatedAt "2026-03-08T03:28:31.687652+00:00"^^xsd:dateTime .

sdc4:DMBaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a label" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-label ],
        [ sh:datatype xsd:language ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify a language" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-language ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must specify encoding" ;
            sh:minCount 1 ;
            sh:path sdc4:dm-encoding ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Data Model must have a mandatory instance_id (CUID2)" ;
            sh:minCount 1 ;
            sh:path sdc4:instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_instance_id ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sdc4:source_version_id ] ;
    sh:targetClass sdc4:DMType .

sdc4:mc-atdtdfzruh7tya0iv5cz365l-shape a sh:NodeShape ;
    rdfs:label "City" ;
    rdfs:comment "One of the nine cities in the Republic of Cordova." ;
    sh:node sdc4:XdTokenBaseShape ;
    sh:property [ rdfs:label "City" ;
            sh:hasValue <http://schema.org/City> ;
            sh:path rdfs:isDefinedBy ],
        [ sh:datatype xsd:token ;
            sh:in ( "Porto Sereno" "Vistamar" "Rioseco" "Campoluz" "Tierraverde" "Montecara" "Novaciudad" "Piedrasol" "Lagunavista" ) ;
            sh:path sdc4:xdtoken-value ],
        [ rdfs:label "skos:ConceptScheme" ;
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ],
        [ rdfs:label "schema:DefinedTermSet" ;
            sh:hasValue schema:DefinedTermSet ;
            sh:path skos:exactMatch ] ;
    sh:targetNode sdc4:mc-atdtdfzruh7tya0iv5cz365l ;
    sdc4-meta:sdcType "XdTokenType" .

sdc4:mc-bgc4n3424bzb8gpgnjhxxha9-shape a sh:NodeShape ;
    rdfs:label "Property Record" ;
    rdfs:comment """A registered land parcel or property in Cordova.
Business Context: Links to Civil Registry (person owners) and Business Registry (business owners)
Purpose: Document a property with location, type, and current ownership""" ;
    sh:node sdc4:ClusterBaseShape ;
    sh:property [ sh:node sdc4:mc-hs7197k4s33eg7wbspgudu4u-shape ;
